# OpsChain Website Environment Variables
# Copy this file to .env.local and fill in the values

# Salesforce Web-to-Lead org ID
NEXT_PUBLIC_SF_ORG_ID=

# Google Tag Manager container ID
NEXT_PUBLIC_GTM_ID=

# Canonical site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://opschain.io

# Show draft blog posts (local development only, never set in production)
NEXT_PUBLIC_SHOW_DRAFTS=false

# NOTE: NODE_ENV is controlled by Next.js automatically:
#   next dev   → development
#   next build → production
# Setting NODE_ENV in .env.local has no effect.

# Dev server port (default: 3000)
# NOTE: PORT must be set as a shell environment variable (export PORT=3899),
# not in .env.local — the npm script reads it before Next.js loads .env.local.
PORT=3000

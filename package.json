{
    "name": "opschain-website",
    "version": "4.2.AI",
    "private": true,
    "scripts": {
        "dev": "rm -rf .next && next dev --port ${PORT:-3000}",
        "build": "rm -rf .next && next build",
        "postbuild": "next-sitemap",
        "start": "next start",
        "lint": "next lint",
        "prettier:write": "prettier --write .",
        "prettier:check": "prettier --check .",
        "prepare": "husky || true"
    },
    "dependencies": {
        "clsx": "^2.1.1",
        "framer-motion": "^12.38.0",
        "next": "^15.3.3",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "velite": "^0.3.1"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.1",
        "@tailwindcss/postcss": "^4.1.8",
        "@types/node": "^22.15.0",
        "@types/react": "^19.1.0",
        "@types/react-dom": "^19.1.0",
        "eslint": "^9.27.0",
        "eslint-config-next": "^15.3.3",
        "husky": "^9.1.7",
        "lint-staged": "^16.2.4",
        "next-sitemap": "^4.2.3",
        "postcss": "^8.5.4",
        "prettier": "^3.6.2",
        "tailwindcss": "^4.1.8",
        "typescript": "5.9.3"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx,json,css,md,mdx}": "prettier --write"
    },
    "engines": {
        "node": ">=22.20"
    }
